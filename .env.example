# QuoteMind environment (QM-SPEC-001 §4.7). Copy to .env; never commit real keys.
# Required (P0) — the API function fails fast at cold start if any is missing.
DASHSCOPE_API_KEY=sk-your-model-studio-key
ALIBABA_CLOUD_ACCESS_KEY_ID=your-ram-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-ram-access-key-secret
TABLESTORE_ENDPOINT=https://quotemind.ap-southeast-1.ots.aliyuncs.com
TABLESTORE_INSTANCE=quotemind
MAIL_FROM=quotes@demo.cyberskill.world
DEMO_API_TOKEN=change-me-to-a-random-32-char-token

# DashScope international (Singapore), OpenAI-compatible mode.
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# OSS (Singapore). Bucket names are frozen (parent §12.6).
OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com
OSS_BUCKET_INBOX=quotemind-inbox
OSS_BUCKET_ARTIFACTS=quotemind-artifacts

# DirectMail SMTP. Default transport is the stub (FR-093); set MAIL_TRANSPORT=smtp
# and provide DIRECTMAIL_USER / DIRECTMAIL_PASSWORD to send real mail.
MAIL_TRANSPORT=stub
DIRECTMAIL_SMTP_HOST=smtpdm-ap-southeast-1.aliyun.com
DIRECTMAIL_SMTP_PORT=465
DIRECTMAIL_USER=
DIRECTMAIL_PASSWORD=

# Pricing / quote policy.
FX_USD_VND=25400
MARGIN_FLOOR_PCT=5
QUOTE_VALIDITY_DAYS=14

# Observability + runtime switch.
OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental
QM_ENV=local
REGION=ap-southeast-1

# SLS project that Function Compute writes logs to (FR-008). Created by FC when you first enable
# logging on the function; `s deploy` needs the name so it does not erase the config on every push.
SLS_PROJECT=serverless-<region>-<account-uuid>
